# Copy this file to .env (local) or .env.staging (staging) and fill in the values.

# API base URL (no trailing slash, no /api suffix)
# Local:   http://192.168.x.x:5001   (your PC's LAN IP)
# Staging: https://api-dev.xalonhub.com
# Prod:    https://api.xalonhub.com
EXPO_PUBLIC_API_URL=

# Environment label (development | staging | production)
EXPO_PUBLIC_APP_ENV=development
