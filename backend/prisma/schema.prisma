generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id                      String           @id @default(uuid())
  partnerId               String?
  clientId                String?
  guestName               String?
  status                  BookingStatus    @default(Requested)
  bookingDate             DateTime
  services                Json
  totalAmount             Int
  discounts               Int              @default(0)
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime @updatedAt
  bookingCity             String?
  bookingLat              Float?
  bookingLng              Float?
  customerId              String?
  serviceMode             String?
  timeSlot                String?
  beneficiaryName         String?
  beneficiaryPhone        String?
  partnerConfirmedReceipt Boolean          @default(false)
  paymentDetails          Json?
  paymentMethod           String?
  paymentStatus           String           @default("Pending")
  serviceGender           String?
  declinedPartnerIds      String[]         @default([])
  guestId                 String?
  partnerEarnings         Int?
  platformFee             Int?
  stylistId               String?
  stylistNameAtBooking    String?
  client                  Client?          @relation(fields: [clientId], references: [id])
  customerProfile         CustomerProfile? @relation(fields: [customerId], references: [id])
  userGuest               UserGuest?       @relation(fields: [guestId], references: [id])
  partnerProfile          PartnerProfile?  @relation(fields: [partnerId], references: [id])
  stylist                 Stylist?         @relation(fields: [stylistId], references: [id])
  review                  Review?
  transactions            Transaction[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  image       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id             String         @id @default(uuid())
  partnerId      String
  name           String
  phone          String
  email          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime @updatedAt
  bookings       Booking[]
  partnerProfile PartnerProfile @relation(fields: [partnerId], references: [id])
}

model CustomerProfile {
  id           String         @id @default(uuid())
  userId       String         @unique
  name         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime @updatedAt
  gender       String?
  dob          String?
  email        String?
  profileImage String?
  bookings       Booking[]
  user           User           @relation(fields: [userId], references: [id])
  savedAddresses SavedAddress[]
  userGuests      UserGuest[]
}

model Deal {
  id             String         @id @default(uuid())
  serviceId      String
  title          String
  description    String?
  discountPct    Int?
  dealPrice      Int
  applicableTo   String[]
  validFrom      DateTime       @default(now())
  validUntil     DateTime?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime @updatedAt
  serviceCatalog ServiceCatalog @relation(fields: [serviceId], references: [id])
}

model GlobalSettings {
  id                String   @id @default("global")
  platformFee       Int      @default(10)
  freelancerCommApp Int      @default(15)
  freelancerCommMan Int      @default(10)
  salonCommApp      Int      @default(0)
  salonCommMan      Int      @default(0)
  updatedAt         DateTime @updatedAt
  platformFeeManual Int      @default(0)
}

model PartnerProfile {
  id                  String              @id @default(uuid())
  userId              String              @unique
  partnerType         PartnerType
  basicInfo           Json?
  address             Json?
  categories          String[]
  workPreferences     Json?
  workingHours        Json?
  documents           Json?
  bankDetails         Json?
  professionalDetails Json?
  salonServices       Json?
  coverImages         String[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime @updatedAt
  isFeatured          Boolean             @default(false)
  rankingWeight       Float               @default(1.0)
  tags                String[]
  salonCover          Json?
  isOnboarded         Boolean             @default(false)
  kycRejectedReason   String?
  kycStatus           String              @default("pending")
  contractAccepted    Boolean             @default(false)
  contractAcceptedAt  DateTime?
  softLockBookingId   String?
  softLockUntil       DateTime?
  isOnline            Boolean             @default(true)
  lastStatusUpdate    DateTime            @default(now())
  averageRating       Float               @default(0.0)
  totalReviews        Int                 @default(0)
  bookings          Booking[]
  clients           Client[]
  user              User                @relation(fields: [userId], references: [id])
  reviews           Review[]
  settlementRequests SettlementRequest[]
  stylists          Stylist[]
}

model Review {
  id             String         @id @default(uuid())
  bookingId      String         @unique
  partnerId      String
  rating         Int?
  reviewText     String?
  partnerNote    String?
  partnerNoteAt  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime @updatedAt
  booking        Booking        @relation(fields: [bookingId], references: [id])
  partnerProfile PartnerProfile @relation(fields: [partnerId], references: [id])
}

model SavedAddress {
  id              String          @id @default(uuid())
  customerId      String
  label           String
  addressLine     String
  city            String
  pincode         String?
  lat             Float?
  lng             Float?
  isDefault       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  district        String?
  state           String?
  customerProfile CustomerProfile @relation(fields: [customerId], references: [id])
}

model ServiceCatalog {
  id            String   @id @default(uuid())
  name          String
  category      String
  subCategory   String?
  description   String?
  duration      Int      @default(30)
  priceType     String   @default("Fixed")
  defaultPrice  Int
  specialPrice  Int?
  maxQuantity   Int      @default(3)
  gender        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  pricingByRole Json?
  image         String?
  faqs          Json?
  steps         Json?
  deals         Deal[]
}

model SettlementRequest {
  id             String         @id @default(uuid())
  partnerId      String
  amount         Int
  payoutMethod   String
  status         String         @default("Processing")
  requestedAt    DateTime       @default(now())
  processedAt    DateTime?
  paytmOrderId   String         @unique
  paytmResponse  Json?
  failureReason  String?
  partnerProfile PartnerProfile @relation(fields: [partnerId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   // Booking, System, Promo
  isRead    Boolean  @default(false)
  metadata  Json?    // { bookingId: "..." }
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique // Expo push token
  deviceId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Stylist {
  id             String         @id @default(uuid())
  partnerId      String
  name           String
  phone          String?
  categories     String[]
  gender         String?
  experience     String?
  bio            String?
  profileImage   String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime @updatedAt
  bookings       Booking[]
  partnerProfile PartnerProfile @relation(fields: [partnerId], references: [id])
}

model Transaction {
  id           String   @id @default(uuid())
  bookingId    String
  gateway      String   @default("Paytm")
  gatewayTxnId String?
  amount       Int
  status       String
  payload      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  booking      Booking  @relation(fields: [bookingId], references: [id])
}

model User {
  id                       String           @id @default(uuid())
  phone                    String           @unique
  email                    String?
  role                     Role             @default(Customer)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime @updatedAt
  emailVerified            Boolean          @default(false)
  emailVerificationExpires DateTime?
  emailVerificationToken   String?
  
  // Notification Preferences
  whatsappTransactional    Boolean          @default(true)
  whatsappMarketing        Boolean          @default(false)
  pushNotifications        Boolean          @default(true)
  hasSetPreferences        Boolean          @default(false)
  preferencesUpdatedAt     DateTime?

  customerProfile          CustomerProfile?
  partnerProfile           PartnerProfile?
  notifications            Notification[]
  pushTokens               PushToken[]
}

model UserGuest {
  id              String          @id @default(uuid())
  customerId      String
  name            String
  mobileNumber    String?
  relationship    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime @updatedAt
  bookings        Booking[]
  customerProfile CustomerProfile @relation(fields: [customerId], references: [id])
}

enum BookingStatus {
  Requested
  Confirmed
  Completed
  Cancelled
  InProgress
}

enum PartnerType {
  Freelancer
  Male_Salon
  Female_Salon
  Unisex_Salon
}

enum Role {
  Customer
  Freelancer
  Male_Salon
  Female_Salon
  Unisex_Salon
  Admin
}
