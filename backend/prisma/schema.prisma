generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Customer
  Freelancer
  Male_Salon
  Female_Salon
  Unisex_Salon
  Admin
}

enum PartnerType {
  Freelancer
  Male_Salon
  Female_Salon
  Unisex_Salon
}

enum BookingStatus {
  Requested
  Confirmed
  InProgress
  Completed
  Cancelled
}

model User {
  id                      String           @id @default(uuid())
  phone                   String           @unique
  email                   String?
  emailVerified           Boolean          @default(false)
  emailVerificationToken  String?
  emailVerificationExpires DateTime?
  role                    Role             @default(Customer)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  partnerProfile  PartnerProfile?
  customerProfile CustomerProfile?
}

model CustomerProfile {
  id           String         @id @default(uuid())
  userId       String         @unique
  user         User           @relation(fields: [userId], references: [id])
  name         String?
  gender       String?        // 'Male', 'Female', 'Other'
  email        String?
  dob          String?        // ISO date string or similar
  profileImage String?        // URL to the image
  addresses    SavedAddress[]
  bookings     Booking[]
  guests       UserGuest[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model UserGuest {
  id           String          @id @default(uuid())
  customerId   String
  customer     CustomerProfile @relation(fields: [customerId], references: [id])
  name         String
  mobileNumber String?
  relationship String?         // "Wife", "Son", "Daughter", "Friend", etc.
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  bookings     Booking[]
}

model SavedAddress {
  id          String          @id @default(uuid())
  customerId  String
  customer    CustomerProfile @relation(fields: [customerId], references: [id])
  label       String          // "Home", "Work", "Other"
  addressLine String
  state       String?
  district    String?
  city        String
  pincode     String?
  lat         Float?
  lng         Float?
  isDefault   Boolean         @default(false)
  createdAt   DateTime        @default(now())
}

model PartnerProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  partnerType         PartnerType

  // Basic Info
  basicInfo           Json?    // { name, email, gender, dob, salonName, ownerName }
  address             Json?    // { street, city, pincode, lat, lng }
  categories          String[] // ["Hair", "Makeup", "Nails"]
  workPreferences     Json?    // { genderPreference, locationType }
  workingHours        Json?    // [ { dayName, isOpen, openTime, closeTime } ]
  documents           Json?    // { aadhaarUrl, panUrl, kycStatus }
  professionalDetails Json?    // { experienceYears, certifications }
  salonServices       Json?    // [ { serviceId, price, duration } ]
  salonCover          Json?    // { inside: [], outside: [] }
  isOnboarded         Boolean   @default(false)
  contractAccepted    Boolean   @default(false)
  contractAcceptedAt  DateTime?
  coverImages         String[]

  // Future-ready hooks (V0: no logic, data model only)
  tags                String[] // Premium / Verified / Top Rated – empty in V0
  rankingWeight       Float    @default(1.0) // for future ranking
  isFeatured          Boolean  @default(false) // for featured placement

  // KYC
  kycStatus           String   @default("pending") // pending | under_review | approved | rejected
  kycRejectedReason   String?
  
  // Soft-lock for auto-assignment
  softLockUntil       DateTime?
  softLockBookingId   String?

  isOnline            Boolean   @default(true)
  lastStatusUpdate    DateTime  @default(now())

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  clients             Client[]
  bookings            Booking[]
  stylists            Stylist[]
}

model Stylist {
  id              String         @id @default(uuid())
  partnerId       String
  partner         PartnerProfile @relation(fields: [partnerId], references: [id])
  name            String
  phone           String?
  categories      String[]       // Matches service categories (e.g., ["Hair", "Makeup"])
  gender          String?        // "Male" | "Female" | "Unisex"
  experience      String?        // e.g., "5 years"
  bio             String?
  profileImage    String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  bookings        Booking[]
}

model ServiceCatalog {
  id           String   @id @default(uuid())
  name         String
  category     String
  subCategory  String?
  description  String?
  duration     Int      @default(30)
  priceType    String   @default("Fixed")
  defaultPrice Int                   // Global fallback price (used when no role-specific price exists)
  specialPrice Int?                  // Global fallback special price

  // Role-scoped pricing overrides:
  // { "Freelancer": { "defaultPrice": 300, "specialPrice": 250 }, "Male_Salon": { ... }, ... }
  // When set, these values take priority over the global defaultPrice/specialPrice for that role.
  pricingByRole Json?               // Keyed by PartnerType enum values

  maxQuantity  Int      @default(3)
  gender       String?  // 'Male', 'Female', 'Unisex'

  deals        Deal[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// V0: Data model only — no business logic or UI yet.
// Deals are role-aware from day one via applicableTo.
model Deal {
  id           String         @id @default(uuid())
  serviceId    String
  service      ServiceCatalog @relation(fields: [serviceId], references: [id])
  title        String
  description  String?
  discountPct  Int?           // e.g. 20 → 20% off
  dealPrice    Int            // Absolute discounted price shown to customer
  // Which partner-type roles this deal applies to.
  // e.g. ["Freelancer"] or ["Male_Salon", "Female_Salon", "Unisex_Salon"]
  applicableTo String[]       // PartnerType values
  validFrom    DateTime       @default(now())
  validUntil   DateTime?      // null = no expiry
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Client {
  id         String         @id @default(uuid())
  partnerId  String
  partner    PartnerProfile @relation(fields: [partnerId], references: [id])
  name       String
  phone      String
  email      String?

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  bookings   Booking[]
}

model Booking {
  id               String          @id @default(uuid())

  // Partner (assigned provider)
  partnerId        String?
  partner          PartnerProfile? @relation(fields: [partnerId], references: [id])

  // Customer (app user)
  customerId       String?
  customer         CustomerProfile? @relation(fields: [customerId], references: [id])

  // CRM Client (walk-in / partner-side)
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id])
  guestId          String?
  guest            UserGuest?      @relation(fields: [guestId], references: [id])
  guestName        String?

  // Stylist (specific assigned professional in a salon)
  stylistId        String?
  stylist          Stylist?        @relation(fields: [stylistId], references: [id])

  // Service mode for customer bookings
  serviceMode      String?         // "AtHome" | "AtSalon"

  status           BookingStatus   @default(Requested)
  bookingDate      DateTime
  timeSlot         String?         // e.g. "10:00"

  // Array of services added to the bill
  services         Json            // [ { catalogId, serviceName, quantity, priceAtBooking } ]
  totalAmount      Int
  discounts        Int             @default(0)
  notes            String?

  // Location snapshot at booking time
  bookingCity      String?
  bookingLat       Float?
  bookingLng       Float?

  // Recipient info
  serviceGender    String?         // "Male" | "Female" | "Unisex"
  beneficiaryName  String?
  beneficiaryPhone String?

  // Payment info
  paymentMethod    String?         // "Online" | "Cash"
  paymentStatus    String          @default("Pending") // "Pending" | "Paid" | "Failed"
  partnerConfirmedReceipt Boolean  @default(false)
  paymentDetails   Json?           // Gateway response, checksums, etc.

  // Future split tracking
  platformFee      Int?            // convenience fee / commission
  partnerEarnings  Int?            // amount to be transferred to partner
  declinedPartnerIds String[]        @default([]) // Track partners who declined

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  transactions     Transaction[]
}

model Transaction {
  id              String   @id @default(uuid())
  bookingId       String
  booking         Booking  @relation(fields: [bookingId], references: [id])
  
  gateway         String   @default("Paytm")
  gatewayTxnId    String?
  amount          Int
  status          String   // "Pending", "Success", "Failed"
  payload         Json?    // raw callback or initiation response
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
